# ─────────────────────────────────────────────────────────────
# InterviewSync — Environment Variables
# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.
# ─────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────

# Secret key for JWT signing and Flask sessions.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-string

# ── Database ─────────────────────────────────────────────────

# Full PostgreSQL URL (takes precedence over individual vars below)
# DATABASE_URL=postgresql://interviewsync:password@db:5432/interviewsync

# Or set each part individually:
DB_USER=interviewsync
DB_PASSWORD=devpassword
DB_HOST=db
DB_PORT=5432
DB_NAME=interviewsync

# ── AI (Groq) ─────────────────────────────────────────────────

# Free API key from https://console.groq.com
AI_API_KEY=

# ── WhatsApp / Twilio (optional) ─────────────────────────────

# Twilio credentials for WhatsApp notifications.
# Leave blank to disable WhatsApp (app still works without it).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Frontend ─────────────────────────────────────────────────

# URL the frontend uses to reach the backend (inside Docker: http://backend:8000)
BACKEND_URL=http://localhost:8000

# URL sent in WhatsApp confirmation links (must be publicly reachable)
FRONTEND_URL=http://localhost:5000

# ── Dev options ──────────────────────────────────────────────

# Set to "true" to enable Flask debug mode (never in production)
FLASK_DEBUG=false
